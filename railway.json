{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "daphne -b 0.0.0.0 -p $PORT kickoff.asgi:application",
    "healthcheckPath": "/api/",
    "restartPolicyType": "ON_FAILURE"
  }
}