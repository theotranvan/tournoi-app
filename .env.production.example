# ─── Kickoff Production Environment ────────────────────────
# Copy to .env.production and fill in real values

# ─── Backend ───────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_50_CHAR_STRING
DEBUG=False
ALLOWED_HOSTS=kickoff.app,api.kickoff.app
FRONTEND_URL=https://kickoff.app
DJANGO_SETTINGS_MODULE=kickoff.settings.prod

# Database
DATABASE_URL=postgres://kickoff:STRONG_PASSWORD_HERE@postgres:5432/kickoff
POSTGRES_DB=kickoff
POSTGRES_USER=kickoff
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS
CORS_ALLOWED_ORIGINS=https://kickoff.app,https://api.kickoff.app

# Security
SECURE_SSL_REDIRECT=False

# Sentry (optional)
SENTRY_DSN=

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.kickoff.app/api/v1
NEXT_PUBLIC_WS_URL=wss://api.kickoff.app/ws

# ─── Nginx ─────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
