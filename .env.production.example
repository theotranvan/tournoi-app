# ─── Footix Production Environment ─────────────────────────
# Copy to .env.production and fill in real values

# ─── Backend ───────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_50_CHAR_STRING
DEBUG=False
ALLOWED_HOSTS=footix.app,api.footix.app
FRONTEND_URL=https://footix.app
DJANGO_SETTINGS_MODULE=kickoff.settings.prod

# Database
DATABASE_URL=postgres://kickoff:STRONG_PASSWORD_HERE@postgres:5432/kickoff
POSTGRES_DB=kickoff
POSTGRES_USER=kickoff
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0

# CORS
CORS_ALLOWED_ORIGINS=https://footix.app,https://api.footix.app

# Security
# Keep False when nginx handles SSL termination (avoids redirect loop)
SECURE_SSL_REDIRECT=False

# CSRF trusted origins (defaults to CORS_ALLOWED_ORIGINS)
# CSRF_TRUSTED_ORIGINS=https://footix.app,https://api.footix.app

# Admin email for Django error emails (optional)
# ADMIN_EMAIL=admin@footix.app

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_xxx_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_xxx_REPLACE_ME
STRIPE_PRICE_ONE_SHOT=price_xxx_REPLACE_ME
STRIPE_PRICE_CLUB_MONTHLY=price_xxx_REPLACE_ME
STRIPE_PRICE_CLUB_YEARLY=price_xxx_REPLACE_ME

# ─── Push notifications (Web Push VAPID) ───────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@footix.app

# ─── Sentry ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Email (transactionnel) ────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_xxx_REPLACE_ME
DEFAULT_FROM_EMAIL=Footix <noreply@footix.app>

# ─── Médias S3 (Scaleway compatible) ───────────────────────
USE_S3_MEDIA=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=footix-media
AWS_S3_REGION_NAME=fr-par
AWS_S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
AWS_S3_CUSTOM_DOMAIN=footix-media.s3.fr-par.scw.cloud

# ─── Backup offsite S3 ────────────────────────────────────
# Same credentials as above (or separate bucket)
S3_BUCKET=footix-backups
BACKUP_RETENTION=30

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.footix.app/api/v1
NEXT_PUBLIC_WS_URL=wss://api.footix.app/ws

# ─── Nginx ─────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
